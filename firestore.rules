rules_version = '2';

// ─────────────────────────────────────────────────────────────────────
//  Gifty Antivirus — Firestore security rules
//  Project: giftyantivirus
//
//  Paste this in the Firebase Console:
//      Firestore Database → Rules → "Publish"
//
//  WHY THIS MATTERS
//  ----------------
//  The default "test mode" rules (allow read, write: if request.time <
//  timestamp.date(...)) make every document publicly readable AND
//  writable to anyone on the internet who knows the project ID. These
//  rules close that hole and restrict the database to exactly the
//  three writes the client makes.
//
//  WHAT THESE RULES ALLOW
//  ----------------------
//   • /events/{id}         create-only, no read, no update, no delete
//   • /detections/{id}     create-only, no read, no update, no delete
//   • /installs/{install_id}  create or update only when the document
//                          ID matches the install_id field; no read,
//                          no delete
//   • everything else      denied
//
//  Reads (for your own dashboards) should go through the Firebase
//  Admin SDK on a server you control, NOT through these public rules.
// ─────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: a payload looks like a telemetry event
    function isTelemetryEvent() {
      return request.resource.data.keys().hasAll(['install_id', 'version', 'os', 'time'])
          && request.resource.data.install_id is string
          && request.resource.data.install_id.size() > 0
          && request.resource.data.install_id.size() < 64
          && request.resource.data.version is string
          && request.resource.data.os is string
          && request.resource.data.time is string
          // Reject any field that could be PII — defense in depth.
          && !('hostname' in request.resource.data)
          && !('username' in request.resource.data)
          && !('file' in request.resource.data)
          && !('filepath' in request.resource.data)
          && !('threat' in request.resource.data);
    }

    match /events/{id} {
      allow create: if isTelemetryEvent()
                    && request.resource.data.event is string
                    && request.resource.data.event.size() < 64;
      allow read, update, delete: if false;
    }

    match /detections/{id} {
      allow create: if isTelemetryEvent()
                    && request.resource.data.category is string
                    && request.resource.data.severity is string
                    && request.resource.data.source is string;
      allow read, update, delete: if false;
    }

    match /installs/{install_id} {
      // Document ID must match the install_id field — prevents one
      // client overwriting another client's heartbeat.
      allow create, update: if isTelemetryEvent()
                           && request.resource.data.install_id == install_id;
      allow read, delete: if false;
    }

    // Catch-all: deny everything else (including the old /users
    // collection that the previous build wrote hostnames into).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
